#!/bin/bash
# commit 前，自動把有變動的 .user.js 的 @version 最後一段數字 +1
# 支援兩段式（1.2 -> 1.3）與三段式（1.6.0 -> 1.6.1）；沒有 @version 則略過

bumped=()
while IFS= read -r -d '' f; do
  [ -z "$f" ] && continue
  [[ "$f" == *.user.js ]] || continue
  [ -f "$f" ] || continue

  # 取出目前版本（數字與點組成，至少一段）
  ver=$(grep -oE '@version[[:space:]]+[0-9][0-9.]*' "$f" | head -1 | grep -oE '[0-9][0-9.]*')
  [ -z "$ver" ] && continue

  # 把最後一段 +1
  last="${ver##*.}"
  if [ "$ver" = "$last" ]; then
    newver=$((ver + 1))            # 沒有點，純數字
  else
    newver="${ver%.*}.$((last + 1))"
  fi

  # 用 \Q...\E 把舊版本當字面字串取代
  perl -i -pe "s/(\@version\s+)\Q$ver\E/\${1}$newver/" "$f"
  git add "$f"
  bumped+=("$f: $ver -> $newver")
done < <(git -c core.quotepath=false diff --cached --name-only -z --diff-filter=ACM)

if [ ${#bumped[@]} -gt 0 ]; then
  echo "已自動更新版本號："
  printf '  %s\n' "${bumped[@]}"
fi
exit 0
